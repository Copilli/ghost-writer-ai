# Ejemplo de archivo .env
# Copia este archivo a .env y agrega tus valores

# Opción 1: Usar API Gateway de Copilli (Recomendado para producción)
VITE_USE_GATEWAY=true
VITE_API_GATEWAY_URL=https://copilli-api-gateway.onrender.com
VITE_API_SECRET_KEY=tu-secret-key-del-gateway

# Opción 2: Usar API directamente (Solo para desarrollo local)
# Comenta USE_GATEWAY y agrega tu API key
# VITE_USE_GATEWAY=false
# VITE_GEMINI_API_KEY=tu-api-key-de-gemini
